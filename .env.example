# ---------- App ----------
# If you kept the refactor layout:
# app.main:app is the ASGI path in Dockerfile command

# ---------- Database ----------
POSTGRES_DB=wedding_faces
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# SQLAlchemy URL (inside docker network, hostname = db)
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/wedding_faces

# ---------- Redis ----------
REDIS_URL=redis://redis:6379

# ---------- Spaces (S3-compatible) ----------
# Use your DO Spaces key/secret
AWS_ACCESS_KEY_ID=DO_SPACES_KEY
AWS_SECRET_ACCESS_KEY=DO_SPACES_SECRET

# Your bucket name (without URL)
AWS_S3_BUCKET=my-wedding-space

# Region slug used by Spaces (nyc3, ams3, sgp1, etc.)
AWS_REGION=nyc3

# Spaces endpoint (required for boto3 with Spaces)
# Format: https://<region>.digitaloceanspaces.com
S3_ENDPOINT=https://nyc3.digitaloceanspaces.com

# Optional: if you want to force public URL base (CDN or custom domain)
# Example (no trailing slash): https://my-wedding-space.nyc3.cdn.digitaloceanspaces.com
# PUBLIC_S3_BASE_URL=https://my-wedding-space.nyc3.digitaloceanspaces.com

# ---------- Face/Model ----------
VECTOR_DIM=512
INSIGHTFACE_PROVIDER=CPUExecutionProvider

# Model selection (affects speed vs accuracy):
#   buffalo_s = Fast mode (~2-3x faster, good for most cases)
#   buffalo_l = Accurate mode (slower, better quality)
INSIGHTFACE_MODEL=buffalo_s

# Detection size (affects speed vs ability to detect small faces):
#   640x640 = Accurate (catches small faces, slower)
#   320x320 = Fast (recommended, 2x faster)
#   160x160 = Very fast (may miss small/distant faces)
DET_SIZE_W=320
DET_SIZE_H=320

# ---------- Worker Backend ----------
# Choose processing backend:
#   rq    = Redis Queue (self-hosted workers, requires rq-worker container)
#   modal = Modal.com (serverless, pay-per-use, auto-scaling)
WORKER_BACKEND=rq

# Modal settings (only used when WORKER_BACKEND=modal)
# App name must match the name in modal_worker.py
MODAL_APP_NAME=muhyak-face-processor

# ---------- Misc ----------
UPLOAD_DIR=uploads
